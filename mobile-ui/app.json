{
  "expo": {
    "name": "GGHub",
    "slug": "gghub",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon-beyaz.png",
    "scheme": "gghub",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gghub.mobile",
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": [
          "en",
          "tr"
        ],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#d2c6f6",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.gghub.mobile",
      "versionCode": 8,
      "googleServicesFile": "./android/app/google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow GGHub to use Face ID to keep your account securely signed in."
        }
      ],
      "expo-localization",
      "expo-font",
      "./plugins/withGradleEncoding",
      "./plugins/withRemoveSystemAlertWindow",
      [
        "expo-notifications",
        {
          "color": "#0f172a"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GGHub to access your photos for profile picture upload.",
          "cameraPermission": "Allow GGHub to access your camera for profile picture upload.",
          "microphonePermission": false
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.850300912540-hjhir657f7iudq7bnffomai8qs9t0ija"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f5e5cc1-3810-49e4-954e-7bb23f181e24"
      }
    },
    "owner": "ahmetdemiroglu"
  }
}
