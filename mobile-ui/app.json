{
  "expo": {
    "name": "GGHub",
    "slug": "gghub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-beyaz.png",
    "scheme": "gghub",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gghub.mobile",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": ["en", "tr"],
        "CFBundleDevelopmentRegion": "en"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.gghub.mobile",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "./plugins/withGradleEncoding",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GGHub to access your photos for profile picture upload.",
          "cameraPermission": "Allow GGHub to access your camera for profile picture upload."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.850300912540-hjhir657f7iudq7bnffomai8qs9t0ija"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "gghub-mobile"
      }
    }
  }
}
